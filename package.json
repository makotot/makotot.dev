{
  "name": "makotot.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "style:generate": "panda codegen",
    "dev:content": "velite --watch",
    "build:content": "velite --clean",
    "dev:next": "next dev --turbopack",
    "build:next": "next build",
    "dev": "pnpm run style:generate && run-p dev:*",
    "build": "pnpm run style:generate && run-s build:*",
    "start": "next start",
    "lint": "eslint .",
    "tsc": "tsc",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test:unit": "vitest run --project=unit",
    "test:unit:coverage": "vitest run --project=unit --coverage",
    "test:storybook": "vitest run --project=storybook",
    "test:storybook:coverage": "vitest run --project=storybook --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@shikijs/rehype": "4.3.1",
    "@shikijs/transformers": "4.3.1",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.8",
    "react-icons": "5.7.0",
    "rss-parser": "3.13.0",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.5",
    "@pandacss/dev": "1.11.4",
    "@pandacss/eslint-plugin": "0.3.2",
    "@storybook/addon-a11y": "10.5.3",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/addon-onboarding": "10.5.3",
    "@storybook/addon-vitest": "10.5.3",
    "@storybook/nextjs-vite": "10.5.3",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.5.3",
    "npm-run-all2": "9.0.2",
    "pandacss-preset-typography": "0.1.6",
    "playwright": "1.61.1",
    "postcss": "8.5.21",
    "prettier": "3.9.6",
    "storybook": "10.5.3",
    "typescript": "6.0.3",
    "velite": "0.4.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.15.1"
}
